# Copy this file to .env and fill in your values.
# Place .env one level ABOVE the webroot on OVHCloud (outside www/)
# so it is never publicly accessible.
#
# .env is listed in .gitignore — never commit the real .env file.

# MailerSend API token
# Generate at: https://app.mailersend.com/api-tokens
MAILERSEND_API_KEY=mlsn.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
