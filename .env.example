# Copy this file to .env and fill in your values.
# Place .env one level ABOVE the webroot on OVHCloud (outside www/)
# so it is never publicly accessible.
#
# .env is listed in .gitignore — never commit the real .env file.

# DevRev API token
# Generate at: DevRev org → Settings → Security → Access tokens
DEVREV_API_KEY=your_devrev_token_here

# DevRev part DON to attach tickets to
# Open the part in DevRev and copy its DON from the URL
DEVREV_PART_ID=don:core:dvrv-eu-1:devo/xxxx:product/2
